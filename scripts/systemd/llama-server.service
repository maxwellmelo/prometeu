[Unit]
Description=llama.cpp HTTP server (Prometeu master)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/llama.cpp/build
ExecStart=/opt/llama.cpp/build/bin/llama-server \
    -m /opt/models/qwen2.5-1.5b-q4.gguf \
    --rpc 10.0.0.101:50052,10.0.0.102:50052 \
    -ngl 99 \
    -t 2 \
    -c 1024 \
    --host 127.0.0.1 \
    --port 8080
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
