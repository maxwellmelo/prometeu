[Unit]
Description=Prometeu Node Agent (telemetry)
After=network-online.target llama-rpc.service llama-server.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/prometeu-node-agent
EnvironmentFile=-/etc/prometeu/node-agent.env
ExecStart=/opt/prometeu-node-agent/venv/bin/uvicorn app:app --host 0.0.0.0 --port 9100
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
